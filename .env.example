# Copy to `.env` for local dev (or set these in your shell / hosting platform).
# `.env` is gitignored — never commit real secrets.

# MongoDB connection string. Required in production.
# Local fallback (used if unset): mongodb://127.0.0.1:27017/nox
MONGO_URI=

# Node environment: development | production
NODE_ENV=development

# Server port (defaults to 5001)
PORT=5001
